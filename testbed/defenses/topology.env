# topology.env — single source of truth for the DS-Lite deployment the defense
# scripts act on. apply_defense.sh / verify_defenses.sh / verify_legit.sh source
# this file, so the controls are NOT hardwired to one concrete addressing: to
# scale to a different prefix, a different public pool, or N subscribers, edit
# only this file (or override any value from the environment before calling).
#
# Every name here can be overridden by an already-set environment variable, so a
# caller can retarget a single run without editing the file, e.g.
#   CARRIER_PREFIX=2001:db8:beef AFTR_IP6=2001:db8:beef::1 ./apply_defense.sh uRPF on

# Carrier / control-plane addressing -----------------------------------------
: "${CARRIER_PREFIX:=2001:db8:cafe}"          # /64 the softwires live on
: "${AFTR_IP6:=${CARRIER_PREFIX}::10}"        # AFTR carrier address
: "${DNS_IP6:=${CARRIER_PREFIX}::2}"          # ISP recursive resolver
: "${DHCP_SERVER_GLOBAL:=${CARRIER_PREFIX}::1}" # legit DHCPv6 server global addr
: "${ATTACKER_IP6:=${CARRIER_PREFIX}::13a}"   # the carrier access-port under test
: "${PUBLIC_POOL:=192.0.2}"                   # AFTR public IPv4 pool (first 3 octets)

# DoT listener port on the resolver
: "${DOT_PORT:=853}"

# Management plane (SNMP) ----------------------------------------------------
: "${AFTR_MGMT_IP4:=10.99.0.1}"               # AFTR OAM address the agent binds
: "${SNMP_PORT:=161}"
: "${SNMP_SECRET:=S3cr3t-oam-2026}"           # hardened community (ON)
: "${SNMP_PUBLIC:=public}"                     # vulnerable default community (OFF)

# Subscriber roster ----------------------------------------------------------
# One row per B4:  <netns> <lan_gw_ip4> <b4_ip6> <client_netns> <client_ip4> <ct_zone>
# Add a row to add a subscriber; the defense scripts loop over this array, so no
# control needs editing to support a third, fourth, ... B4.
B4S=(
  "b4-1 10.0.1.1 ${CARRIER_PREFIX}::b41 client1 10.0.1.100 1"
  "b4-2 10.0.2.1 ${CARRIER_PREFIX}::b42 client2 10.0.2.100 2"
)

# Resolvers the DNS_RRL toggle is installed on (the abused recursive resolver
# plus each B4 resolver for the LAN-path variant). Derived from the roster.
dns_rrl_targets() { printf '%s\n' dns-server; for e in "${B4S[@]}"; do set -- $e; printf '%s\n' "$1"; done; }

# Helper: iterate the roster.  Usage:  for_each_b4 callback_fn
for_each_b4() { local cb="$1" e; for e in "${B4S[@]}"; do set -- $e; "$cb" "$@"; done; }